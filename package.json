{
  "name": "@kevinpatil/devguard",
  "version": "3.4.0",
  "description": "CLI tool that audits env files, dependencies, and React code quality before your app ships",
  "main": "dist/index.js",
  "bin": {
    "devguard": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "ship": "npm run build && npm test && echo '\\n✅ All checks passed — push with: git push'"
  },
  "keywords": [
    "cli",
    "dotenv",
    "env",
    "environment-variables",
    "validation",
    "devtools",
    "typescript",
    "react",
    "dependencies",
    "security",
    "audit",
    "sarif",
    "supply-chain",
    "linting"
  ],
  "author": "Kevin Patil",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinpatildxd/devguard.git"
  },
  "bugs": {
    "url": "https://github.com/kevinpatildxd/devguard/issues"
  },
  "homepage": "https://github.com/kevinpatildxd/devguard#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/types": "^7.29.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  }
}
