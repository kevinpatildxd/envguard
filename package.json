{
  "name": "@kevinpatil/devguard",
  "version": "2.0.0",
  "description": "CLI tool that validates .env files against .env.example before your app ships",
  "main": "dist/index.js",
  "bin": {
    "devguard": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "keywords": [
    "cli",
    "dotenv",
    "env",
    "environment-variables",
    "validation",
    "devtools",
    "typescript"
  ],
  "author": "Kevin Patil",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinpatildxd/devguard.git"
  },
  "bugs": {
    "url": "https://github.com/kevinpatildxd/devguard/issues"
  },
  "homepage": "https://github.com/kevinpatildxd/devguard#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/types": "^7.29.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
